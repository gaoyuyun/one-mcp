JWT_SECRET=your-very-secret-key
#We are using the GitHub API to find out how many stars npm packages have. get GITHUB_TOKEN from https://github.com/settings/tokens 
#GITHUB_TOKEN=your-github-token
SERVER_ADDRESS=http://localhost:3000
PORT=3000
# Redis is optional in this project, you can use it in production
#REDIS_CONN_STRING="redis://127.0.0.1:6379/0"
# MCP tool call timeout (optional)
# Controls the maximum duration for MCP tool calls (useful for LLM-based MCP services that may take longer)
# Supports time.Duration format (e.g., "120s", "5m", "2m30s") or plain seconds (e.g., "120")
# Default is 5 minutes (300 seconds) if not set
# Increase this value if you have MCP services that depend on slow upstream LLM APIs
#MCP_TOOL_CALL_TIMEOUT=5m
